generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  EMPLEADO
  TERMINAL
}

enum EstadoAsistencia {
  PUNTUAL
  TARDE
}

model Empresa {
  id           String    @id @default(uuid())
  nombre       String
  activo       Boolean   @default(true)
  maxEmpleados Int       @default(20)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  perfiles     Perfil[]
  turnos       Turno[]
  asistencias  Asistencia[]

  @@map("empresas")
}

model Perfil {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  nombre    String
  apellido  String
  rol       Role       @default(EMPLEADO)
  estado    Boolean    @default(true)
  empresaId String?    @map("empresa_id")
  empresa   Empresa?   @relation(fields: [empresaId], references: [id])
  turnoId   String?    @map("turno_id")
  turno     Turno?     @relation(fields: [turnoId], references: [id])
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  asistencias Asistencia[]

  @@map("perfiles")
}

model Turno {
  id             String    @id @default(uuid())
  nombre         String
  horaEntrada    String    @map("hora_entrada")
  horaTolerancia String    @map("hora_tolerancia")
  horaSalida     String    @map("hora_salida")
  activo         Boolean   @default(true)
  empresaId      String    @map("empresa_id")
  empresa        Empresa   @relation(fields: [empresaId], references: [id])
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  perfiles       Perfil[]

  @@map("turnos")
}

model Asistencia {
  id        String             @id @default(uuid())
  empleadoId String             @map("empleado_id")
  empleado   Perfil             @relation(fields: [empleadoId], references: [id])
  empresaId String             @map("empresa_id")
  empresa   Empresa            @relation(fields: [empresaId], references: [id])
  fecha     DateTime           @db.Date
  hora      String
  estado    EstadoAsistencia
  metodo    String             @default("qr")
  createdAt DateTime           @default(now()) @map("created_at")

  @@index([empleadoId, fecha])
  @@index([empresaId, fecha])
  @@map("asistencias")
}
